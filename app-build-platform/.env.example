# Example environment variables
# Copy this file to .env and fill in your values

# SSH Configuration
SSH_USER=your_username
SSH_KEY_PATH=/Users/your_username/.ssh/id_rsa

# Git Repository
GIT_REPO_URL=https://github.com/your-org/lava-app.git

# JWT Secret (change in production)
JWT_SECRET=your-super-secret-jwt-key-change-me

# Workspace Directory
WORKSPACE_DIR=~/app-build-workspace

# Redis (usually no need to change)
REDIS_HOST=redis
REDIS_PORT=6379

# Keychain password (for iOS codesign)
KEYCHAIN_PASSWORD=

# Pgyer API Keys (蒲公英发布)
# API credentials are managed via Web Settings page
PGYER_API_KEY=your_pgyer_api_key
PGYER_API_KEY_JIANGUO=
PGYER_API_KEY_LUPEILONG=
PGYER_API_KEY_ALLENLI=
PGYER_API_KEY_ALANWU=
PGYER_API_KEY_LB=

# App Store & Android store credentials
# Managed via Web UI: Settings → 发布平台配置
# No need to set store-specific env vars here
