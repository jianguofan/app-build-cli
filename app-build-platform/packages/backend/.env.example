# Node environment
NODE_ENV=development

# Server
PORT=3000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_EXPIRES_IN=24h

# SSH Configuration
SSH_USER=your_username
SSH_KEY_PATH=/Users/your_username/.ssh/id_rsa

# Git Repository
GIT_REPO_URL=https://github.com/your-org/lava-app.git

# Workspace
WORKSPACE_DIR=/Users/your_username/app-build-workspace

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# Pgyer (蒲公英)
PGYER_API_KEY=your_pgyer_api_key

# App Store Connect
APPSTORE_ISSUER_ID=your_issuer_id
APPSTORE_KEY_ID=your_key_id
APPSTORE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----
APPSTORE_BUNDLE_ID=com.example.app

# Xiaomi (小米)
XIAOMI_APP_ID=your_app_id
XIAOMI_APP_KEY=your_app_key
XIAOMI_APP_SECRET=your_app_secret

# Huawei (华为)
HUAWEI_CLIENT_ID=your_client_id
HUAWEI_CLIENT_SECRET=your_client_secret
HUAWEI_APP_ID=your_app_id

# Tencent MyApp (应用宝)
TENCENT_ORGANIZATION_ID=your_organization_id
TENCENT_APP_KEY=your_app_key

# VIVO
VIVO_ACCESS_KEY=your_access_key
VIVO_ACCESS_SECRET=your_access_secret
VIVO_PACKAGE_NAME=com.example.app

# OPPO
OPPO_APP_KEY=your_app_key
OPPO_APP_SECRET=your_app_secret
OPPO_PACKAGE_NAME=com.example.app

# 360 Mobile Assistant (可选)
QIHU360_ACCESS_TOKEN=your_access_token
QIHU360_APP_ID=your_app_id
